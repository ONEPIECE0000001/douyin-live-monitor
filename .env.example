# ============================================
# 抖音直播数据监控系统 — 环境变量模板
# ============================================
# 使用方式：
#   1. 复制此文件为 .env
#   2. 填入你的真实密码和密钥
#   3. .env 已被 .gitignore 排除，不会提交到 Git
# ============================================

# Django
DJANGO_SECRET_KEY=your-secret-key-here
DJANGO_DEBUG=True

# MySQL
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=your-password-here
MYSQL_DATABASE=douyin_live

# MongoDB (host/port 当前为默认值，如需修改请同步更改 settings.py)
# MONGO_HOST=localhost
# MONGO_PORT=27017

# Redis (host/port 当前为默认值，如需修改请同步更改 settings.py)
# REDIS_HOST=localhost
# REDIS_PORT=6379
